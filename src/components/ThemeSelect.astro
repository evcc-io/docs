</starlight-theme-cycle>

<script is:inline>
  (function () {
    try {
      var t = localStorage.getItem("starlight-theme");
      if (t !== "light" && t !== "dark") t = "auto";
      var el = document.querySelector("starlight-theme-cycle");
      if (el) el.setAttribute("data-theme", t);
    } catch (e) {}
  })();
</script>

<script>
  type Theme = "auto" | "light" | "dark";
  const order: Theme[] = ["auto", "dark", "light"];
  const storageKey = "starlight-theme";

  const parse = (v: unknown): Theme =>
    v === "light" || v === "dark" || v === "auto" ? v : "auto";

  const load = (): Theme =>
    parse(typeof localStorage !== "undefined" && localStorage.getItem(storageKey));

  function store(theme: Theme) {
    if (typeof localStorage === "undefined") return;
    localStorage.setItem(storageKey, theme === "auto" ? "" : theme);
  }

  const preferredColorScheme = (): "light" | "dark" =>
    matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";

  function apply(theme: Theme) {
    document.documentElement.dataset.theme =
      theme === "auto" ? preferredColorScheme() : theme;
  }

  function syncEl(el: HTMLElement, theme: Theme) {
    el.dataset.theme = theme;
  }

  matchMedia("(prefers-color-scheme: light)").addEventListener("change", () => {
    if (load() === "auto") apply("auto");
  });

  class StarlightThemeCycle extends HTMLElement {
    constructor() {
      super();
      const initial = load();
      apply(initial);
      syncEl(this, initial);

      this.querySelector("button")?.addEventListener("click", () => {
        const current = load();
        const next = order[(order.indexOf(current) + 1) % order.length] ?? "auto";
        apply(next);
        store(next);
        syncEl(this, next);
      });
    }
  }
  customElements.define("starlight-theme-cycle", StarlightThemeCycle);
</script>

<style>
  starlight-theme-cycle {
    display: inline-flex;
    align-items: center;
  }
  .theme-cycle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 0;
    padding: 0.25em;
    margin: -0.25em;
    color: inherit;
    cursor: pointer;
    line-height: 0;
    /* Reserve the icon footprint so the button never collapses while the
       inline script picks the matching icon. */
    min-width: calc(1.5em + 0.5em);
    min-height: calc(1.5em + 0.5em);
  }
  .theme-cycle:hover,
  .theme-cycle:focus-visible {
    color: var(--sl-color-text-accent);
  }
  .theme-icon {
    display: none;
    line-height: 0;
    width: 1.5em;
    height: 1.5em;
  }
  starlight-theme-cycle[data-theme="auto"] .theme-icon-auto,
  starlight-theme-cycle[data-theme="light"] .theme-icon-light,
  starlight-theme-cycle[data-theme="dark"] .theme-icon-dark {
    display: inline-flex;
    align-items: center;
  }
</style>
