---
interface Props {
  src: string;
  title?: string;
  poster?: string | ImageMetadata;
  autoplay?: boolean;
  aspect?: string;
}

const { src, title = "Video", poster: posterProp, autoplay = false, aspect } = Astro.props;
const poster = typeof posterProp === "object" ? posterProp.src : posterProp;
const isYouTube = /youtu\.?be/i.test(src);
const style = aspect ? `aspect-ratio: ${aspect}` : undefined;
---

{
  isYouTube ? (
    <div class="video-wrap">
      <iframe
        src={src}
        title={title}
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      />
    </div>
  ) : autoplay ? (
    <div class="video-wrap" style={style}>
      <video autoplay muted loop playsinline poster={poster} preload="metadata">
        <source src={src} />
      </video>
    </div>
  ) : (
    <div class="video-wrap" style={style}>
      <video controls poster={poster} preload="metadata">
        <source src={src} />
      </video>
    </div>
  )
}

<style>
  .video-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin: 1rem 0;
    border-radius: 0.5rem;
    overflow: hidden;
  }
  .video-wrap iframe,
  .video-wrap video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
</style>
