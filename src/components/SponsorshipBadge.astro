---
interface Props {
  variant: "required" | "free";
}
const { variant } = Astro.props;
const lang = Astro.params.lang === "de" ? "de" : "en";

const texts = {
  de: {
    required: "Sponsortoken erforderlich",
    free: "Kein Sponsortoken nötig",
  },
  en: {
    required: "Sponsor token required",
    free: "No sponsor token required",
  },
};
const t = texts[lang];
const href = `/${lang}/sponsorship`;
---

<a class={`sponsorship-badge sponsorship-badge-${variant}`} href={href}>{t[variant]}</a>

<style>
  .sponsorship-badge {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 999rem;
    font-size: 0.8rem;
    line-height: 1.3;
    font-weight: 500;
    text-decoration: none;
  }
  .sponsorship-badge-required {
    background: var(--sl-color-accent-low);
    color: var(--sl-color-text-accent);
  }
  .sponsorship-badge-required:hover {
    background: var(--sl-color-accent);
    color: #fff;
  }
  .sponsorship-badge-free {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-3);
  }
  .sponsorship-badge-free:hover {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-text);
  }
</style>
