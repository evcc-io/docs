---
import NightlyIcon from "@components/NightlyIcon.astro";
import type { Channel } from "@utils/devices";

interface Props {
  lang: "de" | "en";
  channel: Channel;
  /** URL path segment, e.g. "chargers", "smartswitches". */
  category: string;
}
const { lang, category } = Astro.props;

const releaseHref = `/${lang}/${category}`;

const text =
  lang === "de"
    ? `Diese Seite zeigt die <strong>Nightly-Version</strong> unserer unterstützten Geräte. Wechsle zur <a href="${releaseHref}">Release-Version</a> für die aktuelle stabile Liste.`
    : `This page shows the <strong>nightly version</strong> of our supported devices. Switch to the <a href="${releaseHref}">release version</a> for the current stable list.`;
---

<div class="channel-banner" role="note">
  <NightlyIcon class="channel-icon" />
  <p class="channel-text" set:html={text} />
</div>

<style>
  .channel-banner {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin: 0 0 1.5rem;
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--sl-color-purple);
    border-radius: 0.5rem;
    background: var(--sl-color-purple-low);
    color: var(--sl-color-purple-high);
  }
  .channel-banner :global(.channel-icon) {
    flex-shrink: 0;
    transform: translateY(0.15em);
  }
  .channel-text {
    margin: 0;
    font-size: 0.9rem;
  }
  .channel-text :global(a) {
    color: inherit;
    text-decoration-color: var(--sl-color-purple);
  }
</style>
