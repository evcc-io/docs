---
interface Props {
  lang: "de" | "en";
  kind?: "device" | "service";
  /** When set, the hint also points at the nightly version of the list. */
  nightlyHref?: string;
}

const { lang, kind = "device", nightlyHref } = Astro.props;

const issuesUrl = "https://github.com/evcc-io/evcc/issues/new/choose";
const userDefinedUrl = `/${lang}/user-defined-devices`;
const userDefinedAnchor = kind === "service" ? `${userDefinedUrl}#tariff` : userDefinedUrl;

const featureRequest =
  lang === "de"
    ? `einen <a href="${issuesUrl}">Feature Request</a> auf GitHub`
    : `a <a href="${issuesUrl}">feature request</a> on GitHub`;

const userDefined =
  lang === "de"
    ? kind === "service"
      ? `einen <a href="${userDefinedAnchor}">eigenen Dienst</a> über das Plugin-System`
      : `ein <a href="${userDefinedAnchor}">eigenes Gerät</a> über das Plugin-System`
    : kind === "service"
      ? `your own <a href="${userDefinedAnchor}">user-defined service</a> via the plugin system`
      : `your own <a href="${userDefinedAnchor}">user-defined device</a> via the plugin system`;

const nightly =
  nightlyHref &&
  (lang === "de"
    ? `wirf einen Blick auf die <a href="${nightlyHref}">Nightly-Liste</a>`
    : `check the <a href="${nightlyHref}">nightly list</a>`);

let body: string;
if (lang === "de") {
  body = nightly
    ? `${nightly[0].toUpperCase()}${nightly.slice(1)} für kommende Ergänzungen, eröffne ${featureRequest} oder definiere ${userDefined}.`
    : `Eröffne ${featureRequest} oder definiere ${userDefined}.`;
} else {
  body = nightly
    ? `${nightly[0].toUpperCase()}${nightly.slice(1)} for upcoming additions, open ${featureRequest}, or build ${userDefined}.`
    : `Open ${featureRequest} or build ${userDefined}.`;
}

const title =
  lang === "de"
    ? kind === "service"
      ? "Dein Dienst nicht dabei?"
      : "Dein Gerät nicht dabei?"
    : kind === "service"
      ? "Service not in the list?"
      : "Device not in the list?";
---

<aside class="starlight-aside starlight-aside--note" aria-label={title}>
  <p class="starlight-aside__title" aria-hidden="true">{title}</p>
  <p set:html={body} />
</aside>
