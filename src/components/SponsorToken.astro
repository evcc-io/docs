---
import { Code } from "@astrojs/starlight/components";

// Rotated regularly via external sync — see scripts in evcc-io/evcc that
// update this file. If you're editing manually, also update `title`.
const token =
  "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJldmNjLmlvIiwic3ViIjoidHJpYWwiLCJleHAiOjE3Nzk1Mzc2MDAsImlhdCI6MTc3ODY3MzYwMCwic3BlIjp0cnVlLCJzcmMiOiJtYSJ9.vxS9feZs3WOTkTn_h0rU6quWiIgpTjZws9kd-zWgT60";
const title = "trial token, valid until 2026-05-23";
---

<div class="sponsortoken">
  <Code code={token} lang="text" title={title} wrap />
</div>

<style is:global>
  /* Expressive Code reserves padding-inline-end for the copy button, which
     produces a horizontal scrollbar even when content wraps. Suppress it. */
  .sponsortoken pre {
    overflow-x: hidden;
  }
</style>
