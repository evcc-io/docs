---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import DeviceConfig from "@components/DeviceConfig.astro";
import DeviceFeatures from "@components/DeviceFeatures.astro";
import DeviceParams from "@components/DeviceParams.astro";
import SponsorshipBadge from "@components/SponsorshipBadge.astro";
import NightlyIcon from "@components/NightlyIcon.astro";
import { renderMarkdown, nightlyPageHead } from "@utils/devices";
import type { Channel } from "@utils/devices";
import { deviceIconSvg } from "@utils/deviceIcon";

interface Props {
  entry: any;
  lang: "de" | "en";
  /** Which template channel this page renders. */
  channel: Channel;
  /** Path segment used for the back link and overview URL (e.g. "chargers"). */
  type: string;
  /** Label shown in the back-link breadcrumb, e.g. "PV, Battery, Grid, Meter". */
  categoryLabel: string;
  /** Already-resolved features list. */
  features: string[];
  /** Pre-rendered YAML blocks; used as fallback when no "config" slot provided. */
  codeBlocks?: string[];
  editUrl?: string;
  /**
   * Link to the same device on the other channel. On a release page this points
   * to the nightly version (only set when nightly differs); on a nightly page it
   * points back to release (only set when a release counterpart exists).
   */
  counterpartHref?: string;
}

const {
  entry,
  lang,
  channel,
  type,
  categoryLabel,
  features,
  codeBlocks = [],
  editUrl,
  counterpartHref,
} = Astro.props;

const isNightly = channel === "nightly";

const product = entry.data.product;
const title = product.brand
  ? `${product.brand} ${product.description ?? ""}`.trim()
  : product.description || entry.id;
const requiresSponsorship = entry.data.requirements?.includes("sponsorship");
const isSponsorFree = !requiresSponsorship && features.includes("sponsorfree");
const iconSvg = await deviceIconSvg(type, entry.id);
// "sponsorfree" is a synthetic feature added by featuresFor() for chargers.
// It's surfaced as a header badge here, so drop it from the bullet list.
const visibleFeatures = features.filter((f) => f !== "sponsorfree");

// Back link points at the overview of the same channel.
const overviewHref = `/${lang}${isNightly ? "/nightly" : ""}/${type}`;

const t =
  lang === "de"
    ? {
        config: "Konfigurationsbeispiel für evcc.yaml",
        configHelp:
          "Falls du die Konfiguration nicht über die Oberfläche vornehmen möchtest, kannst du alternativ diesen YAML-Block verwenden.",
        params: "Parameter",
        viewNightly: "Nightly-Version ansehen",
      }
    : {
        config: "Configuration example for evcc.yaml",
        configHelp:
          "If you don't want to configure via the UI, you can alternatively use this YAML block.",
        params: "Parameters",
        viewNightly: "View nightly version",
      };

const nightlyBannerText =
  lang === "de"
    ? counterpartHref
      ? `Diese Seite zeigt die <strong>Nightly-Version</strong>. Wechsle zur <a href="${counterpartHref}">Release-Version</a>.`
      : `Diese Seite zeigt die <strong>Nightly-Version</strong>. Eine Release-Version gibt es noch nicht.`
    : counterpartHref
      ? `This page shows the <strong>nightly version</strong>. Switch to the <a href="${counterpartHref}">release version</a>.`
      : `This page shows the <strong>nightly version</strong>. There is no release version yet.`;

const frontmatter = {
  title,
  description: entry.data.description,
  template: "doc",
  editUrl,
  tableOfContents: false,
  ...(isNightly ? { pagefind: false, head: nightlyPageHead } : {}),
};
---

<StarlightPage frontmatter={frontmatter}>
  <div class="device-detail" data-pagefind-ignore={isNightly ? "" : undefined}>
    <div class="device-header">
      <a class="device-back" href={overviewHref}>← {categoryLabel}</a>
      {requiresSponsorship && <SponsorshipBadge variant="required" />}
      {isSponsorFree && <SponsorshipBadge variant="free" />}
    </div>

    {
      isNightly && (
        <div class="nightly-banner" role="note">
          <NightlyIcon class="nightly-icon" />
          <p class="nightly-text" set:html={nightlyBannerText} />
        </div>
      )
    }

    {iconSvg && <div class="device-icon" aria-hidden="true" set:html={iconSvg} />}

    {
      entry.data.description && (
        <div
          class="device-description"
          set:html={renderMarkdown(entry.data.description)}
        />
      )
    }

    <DeviceFeatures features={visibleFeatures} lang={lang} />

    <slot name="after-features" />

    <div class="params-block">
      <div class="params-header">
        <h2 class="params-title">{t.params}</h2>
      </div>

      <DeviceParams params={entry.data.params ?? []} lang={lang} hideTitle />
    </div>

    <details class="device-config-section">
      <summary>{t.config}</summary>
      <p class="device-config-help">{t.configHelp}</p>
      <slot name="config">
        {codeBlocks.map((code) => <DeviceConfig code={code} />)}
      </slot>
    </details>

    {
      !isNightly && counterpartHref && (
        <p class="nightly-link">
          <a class="channel-link" href={counterpartHref}>
            <NightlyIcon />
            <span>{t.viewNightly}</span>
          </a>
        </p>
      )
    }
  </div>
</StarlightPage>

<style>
  .params-block {
    clear: right;
  }
  .params-header {
    display: flex;
    flex-wrap: wrap-reverse;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem 1rem;
    margin: 2rem 0 0.75rem;
  }
  .params-title {
    margin: 0;
    font-size: 1.25rem;
  }
  /* We own the heading via .params-header now — strip the section's top
     margin so the table sits flush under our heading row. */
  .params-block :global(.device-params) {
    margin-top: 0;
  }
  .nightly-link {
    margin: 2rem 0 0;
    font-size: 0.9rem;
  }
  .channel-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--sl-color-gray-2);
    text-decoration: underline;
    text-decoration-color: var(--sl-color-gray-4);
    text-underline-offset: 0.2em;
  }
  .channel-link:hover {
    color: var(--sl-color-white);
    text-decoration-color: currentColor;
  }

  /* Nightly preview banner at the top of a nightly detail page. */
  .nightly-banner {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin: 0 0 1.5rem;
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--sl-color-purple);
    border-radius: 0.5rem;
    background: var(--sl-color-purple-low);
    color: var(--sl-color-purple-high);
  }
  .nightly-banner :global(.nightly-icon) {
    flex-shrink: 0;
    transform: translateY(0.15em);
  }
  .nightly-text {
    margin: 0;
    font-size: 0.9rem;
  }
  .nightly-text :global(a) {
    color: inherit;
    text-decoration-color: var(--sl-color-purple);
  }
</style>
