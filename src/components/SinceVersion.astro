---
interface Props {
  version: string;
}
const { version } = Astro.props;
const lang = Astro.params.lang === "de" ? "de" : "en";
const label = lang === "de" ? "Ab Version" : "Since version";
---

<span class="since-version">{label} {version}</span>

<style>
  .since-version {
    display: inline-block;
    margin-bottom: 1rem;
    padding: 0.15rem 0.65rem;
    font-size: 0.8rem;
    border-radius: 0.5rem;
    background: var(--sl-color-gray-5);
    color: var(--sl-color-text);
  }
</style>
