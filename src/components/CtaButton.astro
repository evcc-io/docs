---
interface Props {
  href: string;
}

const { href } = Astro.props;
---

<div class="cta-container">
  <a class="cta-button" href={href}><slot /></a>
</div>

<style>
  /* Aligned with the evcc.io homepage button (.content .button) */
  .cta-container {
    text-align: center;
    margin: 3rem 0;
  }
  .cta-button {
    display: inline-block;
    background-color: #0ba631;
    color: #ffffff;
    font-weight: bold;
    font-size: 1.25em;
    padding: 0.75em 2em;
    border-radius: 2em;
    text-decoration: none;
    transition: background-color 0.2s ease-in;
  }
  .cta-button:hover {
    background-color: #076f20;
  }
  :global([data-theme="dark"]) .cta-button {
    background-color: #0fdd42;
    color: #00002d;
  }
  :global([data-theme="dark"]) .cta-button:hover {
    background-color: #0fdd42;
  }
</style>
