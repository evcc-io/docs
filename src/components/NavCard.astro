---
interface Props {
  title: string;
  href?: string;
  to?: string;
  description?: string;
  icon?: string;
  fullWidth?: boolean;
  highlight?: boolean;
}

const { title, href, to, description, icon, fullWidth = false, highlight = false } = Astro.props;
const target = href ?? to ?? "#";
const classes = [
  "nav-card",
  fullWidth ? "nav-card-full" : "",
  highlight ? "nav-card-highlight" : "",
].filter(Boolean).join(" ");
---

<a class={classes} href={target}>
  <h3 class="nav-card-title">
    {icon && <span class="nav-card-icon">{icon}</span>}
    {title}
  </h3>
  {description && <p class="nav-card-desc">{description}</p>}
</a>

<style>
  .nav-card {
    display: block;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    background: var(--sl-color-bg);
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .nav-card:hover {
    border-color: var(--sl-color-text-accent);
    background: var(--sl-color-gray-6);
  }
  .nav-card-full {
    grid-column: 1 / -1;
  }
  .nav-card-highlight {
    border-color: var(--sl-color-text-accent);
  }
  .nav-card-highlight:hover {
    border-color: var(--sl-color-text-accent);
    background: var(--sl-color-gray-6);
  }
  .nav-card-title {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    color: var(--sl-color-text-accent);
    font-weight: 600;
  }
  .nav-card-icon {
    margin-right: 0.5rem;
  }
  .nav-card-desc {
    margin: 0;
    color: var(--sl-color-text);
    font-size: 0.925rem;
    line-height: 1.5;
  }
</style>
