---
import type { ImageMetadata } from "astro";

interface Props {
  /** Path beneath `src/assets/`, e.g. "features/screenshots/solar-mode" */
  name?: string;
  /** Backwards-compat alias for `name`. */
  img?: string;
  alt?: string;
  caption?: string;
  width?: number;
}

const images = import.meta.glob<ImageMetadata>(
  "/src/assets/**/*.{webp,png,jpg,jpeg}",
  { eager: true, import: "default" },
);

function url(base: string, theme: "light" | "dark", dpr: 1 | 2) {
  const key = `/src/assets/${base}-${theme}-${dpr}x.webp`;
  const img = images[key];
  if (!img) {
    throw new Error(`Screenshot: missing asset ${key}`);
  }
  return img.src;
}

const { name, img, alt, caption, width } = Astro.props;
const base = (name ?? img)?.replace(/^\/+/, "");
const altText = alt ?? caption ?? "Screenshot";
---

{
  base && (
    <figure class="screenshot">
      <picture>
        <source
          media="(prefers-color-scheme: dark)"
          srcset={`${url(base, "dark", 1)} 1x, ${url(base, "dark", 2)} 2x`}
        />
        <img
          src={url(base, "light", 1)}
          srcset={`${url(base, "light", 1)} 1x, ${url(base, "light", 2)} 2x`}
          alt={altText}
          width={width}
          loading="lazy"
        />
      </picture>
      {caption && <figcaption>{caption}</figcaption>}
    </figure>
  )
}

<style>
  .screenshot {
    margin: 1rem 0;
  }
  .screenshot img {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
  }
  .screenshot figcaption {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    color: var(--sl-color-gray-3);
  }
</style>
