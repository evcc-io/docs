---
const lang = Astro.params.lang === "de" ? "de" : "en";

const texts = {
  de: {
    label: "Sponsortoken erforderlich",
    href: "/de/sponsorship",
  },
  en: {
    label: "Sponsor token required",
    href: "/en/sponsorship",
  },
};
const t = texts[lang];
---

<a class="sponsorship-required" href={t.href}>{t.label}</a>

<style>
  .sponsorship-required {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    background: var(--sl-color-accent-low);
    color: var(--sl-color-text-accent);
    border-radius: 999rem;
    font-size: 0.8rem;
    line-height: 1.3;
    font-weight: 500;
    text-decoration: none;
  }
  .sponsorship-required:hover {
    background: var(--sl-color-accent);
    color: #fff;
  }
</style>
