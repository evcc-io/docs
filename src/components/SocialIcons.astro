---
import config from "virtual:starlight/user-config";

const links = (config.social ?? []).filter(({ icon }) => icon === "github");
const locale = Astro.locals.starlightRoute.locale ?? "";
const blogHref = locale ? `/${locale}/blog` : "/blog";
const isBlog =
  Astro.url.pathname === blogHref ||
  Astro.url.pathname.startsWith(`${blogHref}/`);
---

<a href={blogHref} class:list={["blog-link", { active: isBlog }]}>Blog</a>

{
  links.length > 0 && (
    <>
      {links.map(({ label, href }) => (
        <a {href} rel="me" class="sl-flex social-link" aria-label={label}>
          <span class="sr-only">{label}</span>
          <svg
              xmlns="http://www.w3.org/2000/svg"
              width="1.5em"
              height="1.5em"
              viewBox="0 0 256 256"
              aria-hidden="true"
            >
              <rect width="256" height="256" fill="none" />
              <path
                d="M119.83,56A52,52,0,0,0,76,32a51.92,51.92,0,0,0-3.49,44.7A49.28,49.28,0,0,0,64,104v8a48,48,0,0,0,48,48h48a48,48,0,0,0,48-48v-8a49.28,49.28,0,0,0-8.51-27.3A51.92,51.92,0,0,0,196,32a52,52,0,0,0-43.83,24Z"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="24"
              />
              <path
                d="M104,232V192a32,32,0,0,1,32-32h0a32,32,0,0,1,32,32v40"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="24"
              />
              <path
                d="M104,208H76a32,32,0,0,1-32-32,32,32,0,0,0-32-32"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="24"
              />
            </svg>
        </a>
      ))}
    </>
  )
}

<style>
  .social-link {
    color: inherit;
    padding: 0.25em;
    margin: -0.25em;
  }
  .social-link:hover,
  .social-link:focus {
    color: var(--sl-color-text-accent);
  }
  .blog-link {
    color: inherit;
    font-size: 1.125rem;
    text-decoration: none;
  }
  .blog-link.active,
  .blog-link:hover,
  .blog-link:focus {
    text-decoration: underline;
  }
</style>
