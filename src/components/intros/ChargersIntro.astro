---
import { featureLabel, featureDescription } from "@components/features";
import { renderMarkdownInline } from "@utils/devices";

interface Props {
  lang: "de" | "en";
}
const { lang } = Astro.props;

const featureKeys = ["1p3p", "rfid", "mA", "meter", "iso15118-2", "dim"];

const t = lang === "de"
  ? {
      intro: "Zur Steuerung der Ladung muss evcc mit einer Wallbox kommunizieren. Auf dieser Seite findest du alle unterstützten Geräte. Über die Filterleisten erkennst du auf einen Blick, welche Funktionen ein Gerät mitbringt.",
      featuresHeading: "Eigenschaften",
    }
  : {
      intro: "To control charging, evcc needs to communicate with your charger. This page lists all supported devices. The filter chips show at a glance which features each device supports.",
      featuresHeading: "Features",
    };
---

<p>{t.intro}</p>

<h2 id="features">{t.featuresHeading}</h2>
<ul>
  {featureKeys.map((f) => (
    <li>
      <strong>{featureLabel(f, lang)}:</strong>{" "}
      <span set:html={renderMarkdownInline(featureDescription(f, lang))} />
    </li>
  ))}
</ul>
