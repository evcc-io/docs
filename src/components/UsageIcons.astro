---
import { usageLabel, USAGE_KEYS } from "@utils/usages";

interface Props {
  usages: string[];
  lang: "de" | "en";
}
const { usages, lang } = Astro.props;

const sorted = [...usages].sort((a, b) => USAGE_KEYS.indexOf(a) - USAGE_KEYS.indexOf(b));
