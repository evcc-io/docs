---
import { getCollection } from "astro:content";
import DeviceDetailLayout from "@components/DeviceDetailLayout.astro";
import DeviceConfig from "@components/DeviceConfig.astro";
import DeviceUsages from "@components/DeviceUsages.astro";
import UsageTabs from "@components/UsageTabs.astro";
import { usageLabel } from "@utils/usages";
import {
  CODE_PREAMBLES,
  indent,
  featuresFor,
  nightlyDiffersFromRelease,
} from "@utils/devices";

export async function getStaticPaths() {
  const paths: any[] = [];
  for (const lang of ["en", "de"] as const) {
    const coll = await getCollection(`meters-${lang}` as any);
    const nightlyColl = await getCollection(`meters-nightly-${lang}` as any);
    const nightlyById = new Map(nightlyColl.map((e: any) => [e.id, e]));
    for (const entry of coll as any[]) {
      const nightlyEntry = nightlyById.get(entry.id);
      paths.push({
        params: { lang, slug: entry.id },
        props: { entry, lang, nightlyEntry },
      });
    }
  }
  return paths;
}

const { entry, lang, nightlyEntry } = Astro.props as {
  entry: any;
  lang: "de" | "en";
  nightlyEntry: any | undefined;
};

const features = featuresFor("meter", entry, lang);
const editUrl = entry.data.template
  ? `https://github.com/evcc-io/evcc/tree/master/templates/definition/meter/${entry.data.template}.yaml`
  : undefined;

function buildTabs(e: any) {
  return (e.data.render as any[] ?? []).map((render) => {
    const usage = render.usage ?? "meter";
    const preamble = CODE_PREAMBLES[usage] ?? CODE_PREAMBLES.meter;
    const src = render.advanced ?? render.default;
    return {
      usage,
      label: usageLabel(usage, lang),
      code: `${preamble}\n${indent(src).trimEnd()}`,
    };
  });
}

const tabs = buildTabs(entry);

const hasNightly = nightlyDiffersFromRelease(entry, nightlyEntry);
const nightlyFeatures = hasNightly ? featuresFor("meter", nightlyEntry, lang) : undefined;
const nightlyTabs = hasNightly ? buildTabs(nightlyEntry) : [];
---

<DeviceDetailLayout
  entry={entry}
  lang={lang}
  type="meters"
  categoryLabel={lang === "de" ? "PV, Batterie, Netz, Zähler" : "PV, Battery, Grid, Meter"}
  features={features}
  editUrl={editUrl}
  nightlyEntry={hasNightly ? nightlyEntry : undefined}
  nightlyFeatures={nightlyFeatures}
>
  <DeviceUsages slot="after-features" renders={entry.data.render ?? []} lang={lang} />
  {hasNightly && (
    <DeviceUsages slot="after-features-nightly" renders={nightlyEntry.data.render ?? []} lang={lang} />
  )}

  <Fragment slot="config">
    {tabs.length === 1 && <DeviceConfig code={tabs[0].code} />}
    {tabs.length > 1 && <UsageTabs tabs={tabs} lang={lang} groupId={entry.id} />}
  </Fragment>
  {hasNightly && (
    <Fragment slot="nightly-config">
      {nightlyTabs.length === 1 && <DeviceConfig code={nightlyTabs[0].code} />}
      {nightlyTabs.length > 1 && (
        <UsageTabs tabs={nightlyTabs} lang={lang} groupId={`${entry.id}-nightly`} />
      )}
    </Fragment>
  )}
</DeviceDetailLayout>
