---
import { getCollection } from "astro:content";
import DeviceDetailLayout from "@components/DeviceDetailLayout.astro";
import {
  CODE_PREAMBLES,
  filterByType,
  indent,
  featuresFor,
  nightlyDiffersFromRelease,
} from "@utils/devices";

export async function getStaticPaths() {
  const paths: any[] = [];
  for (const lang of ["en", "de"] as const) {
    const coll = await getCollection(`chargers-${lang}` as any);
    const nightlyColl = await getCollection(`chargers-nightly-${lang}` as any);
    const nightlyById = new Map(nightlyColl.map((e: any) => [e.id, e]));
    const filtered = filterByType(coll as any, "charger");
    for (const entry of filtered) {
      const nightlyEntry = nightlyById.get(entry.id);
      paths.push({
        params: { lang, slug: entry.id },
        props: { entry, lang, nightlyEntry },
      });
    }
  }
  return paths;
}

const { entry, lang, nightlyEntry } = Astro.props as {
  entry: any;
  lang: "de" | "en";
  nightlyEntry: any | undefined;
};

const features = featuresFor("charger", entry, lang);
const editUrl = entry.data.template
  ? `https://github.com/evcc-io/evcc/tree/master/templates/definition/charger/${entry.data.template}.yaml`
  : undefined;

function buildCodeBlocks(e: any): string[] {
  return (e.data.render as any[] ?? []).map((render) => {
    const preamble = CODE_PREAMBLES[render.usage ?? "charger"] ?? CODE_PREAMBLES.charger;
    const src = render.advanced ?? render.default;
    return `${preamble}\n${indent(src).trimEnd()}`;
  });
}

const codeBlocks = buildCodeBlocks(entry);

const hasNightly = nightlyDiffersFromRelease(entry, nightlyEntry);
const nightlyFeatures = hasNightly ? featuresFor("charger", nightlyEntry, lang) : undefined;
const nightlyCodeBlocks = hasNightly ? buildCodeBlocks(nightlyEntry) : undefined;
---

<DeviceDetailLayout
  entry={entry}
  lang={lang}
  type="chargers"
  categoryLabel={lang === "de" ? "Wallboxen" : "Chargers"}
  brandKey="manufacturer"
  features={features}
  codeBlocks={codeBlocks}
  editUrl={editUrl}
  nightlyEntry={hasNightly ? nightlyEntry : undefined}
  nightlyFeatures={nightlyFeatures}
  nightlyCodeBlocks={nightlyCodeBlocks}
/>
