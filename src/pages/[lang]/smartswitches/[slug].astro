---
import DeviceDetailLayout from "@components/DeviceDetailLayout.astro";
import { deviceDetailPaths, featuresFor, buildCodeBlocks, templateEditUrl } from "@utils/devices";

export const getStaticPaths = () =>
  deviceDetailPaths({ prefix: "chargers", urlType: "smartswitches", channel: "release", filterType: "smartswitch" });

const { entry, lang, counterpartHref } = Astro.props as any;
---

<DeviceDetailLayout
  entry={entry}
  lang={lang}
  channel="release"
  type="smartswitches"
  categoryLabel={lang === "de" ? "Schaltbare Steckdosen" : "Smart switches"}
  features={featuresFor("smartswitch", entry, lang)}
  codeBlocks={buildCodeBlocks(entry, "smartswitch")}
  editUrl={templateEditUrl(entry, "charger")}
  counterpartHref={counterpartHref}
/>
