---
import DeviceDetailLayout from "@components/DeviceDetailLayout.astro";
import { deviceDetailPaths, featuresFor, buildCodeBlocks, templateEditUrl } from "@utils/devices";

export const getStaticPaths = () =>
  deviceDetailPaths({ prefix: "chargers", urlType: "chargers", channel: "nightly", filterType: "charger" });

const { entry, lang, counterpartHref } = Astro.props as any;
---

<DeviceDetailLayout
  entry={entry}
  lang={lang}
  channel="nightly"
  type="chargers"
  categoryLabel={lang === "de" ? "Wallboxen" : "Chargers"}
  features={featuresFor("charger", entry, lang)}
  codeBlocks={buildCodeBlocks(entry, "charger")}
  editUrl={templateEditUrl(entry, "charger")}
  counterpartHref={counterpartHref}
/>
