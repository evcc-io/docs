---
import DeviceDetailLayout from "@components/DeviceDetailLayout.astro";
import { deviceDetailPaths, featuresFor, buildCodeBlocks, templateEditUrl } from "@utils/devices";

export const getStaticPaths = () =>
  deviceDetailPaths({ prefix: "vehicles", urlType: "vehicles", channel: "nightly" });

const { entry, lang, counterpartHref } = Astro.props as any;
---

<DeviceDetailLayout
  entry={entry}
  lang={lang}
  channel="nightly"
  type="vehicles"
  categoryLabel={lang === "de" ? "Fahrzeuge" : "Vehicles"}
  features={featuresFor("vehicle", entry, lang)}
  codeBlocks={buildCodeBlocks(entry, "vehicle")}
  editUrl={templateEditUrl(entry, "vehicle")}
  counterpartHref={counterpartHref}
/>
